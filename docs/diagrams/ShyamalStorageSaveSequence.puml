@startuml
actor User
participant ":Ui" as UI
participant ":InternTrackr" as IT
participant ":Parser" as P
participant "c:AddCommand" as AC
participant ":ApplicationList" as AL
participant ":Storage" as S

IT -> UI : readCommand()
activate UI
User -> UI : types "add c/Google r/SWE"
UI --> IT : "add c/Google r/SWE"
deactivate UI

activate IT
IT -> P : parse("add c/Google r/SWE")
activate P
P --> IT : c (AddCommand)
deactivate P

IT -> AC : execute(applications, ui, storage)
activate AC

AC -> AL : hasApplication(newApp)
activate AL
AL --> AC : false
deactivate AL

alt duplicate exists
    AC -> UI : showMessage("Already tracked...")
    activate UI
    UI --> User : displays warning
    deactivate UI
else not a duplicate
    AC -> AL : addApplication(newApp)
    activate AL
    AL --> AC : done
    deactivate AL

    AC -> UI : showMessage(confirmation + app details)
    activate UI
    UI --> User : displays confirmation
    deactivate UI

    AC -> S : save(applications.getApplications())
    activate S
    S --> AC : done
    deactivate S
end

deactivate AC
deactivate IT
@enduml
