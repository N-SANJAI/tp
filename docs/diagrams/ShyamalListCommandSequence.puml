@startuml
actor User
participant ":Ui" as UI
participant ":InternTrackr" as IT
participant ":Parser" as P
participant "c:ListCommand" as LC
participant ":ApplicationList" as AL

IT -> UI : readCommand()
activate UI
User -> UI : types "list"
UI --> IT : "list"
deactivate UI

activate IT
IT -> P : parse("list")
activate P
P --> IT : c (ListCommand)
deactivate P

IT -> LC : execute(applications, ui, storage)
activate LC

LC -> AL : getApplication(i) for each entry
activate AL
AL --> LC : applications
deactivate AL

alt no active applications
    LC -> UI : showMessage("No applications found. Start adding some!")
    activate UI
    UI --> User : displays output
    deactivate UI
else has active applications
    LC -> UI : showMessage(formatted application list)
    activate UI
    UI --> User : displays list with notes
    deactivate UI
end

deactivate LC
deactivate IT
@enduml
